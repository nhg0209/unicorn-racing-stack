<?xml version="1.0"?>
<!--
  mapping.launch.xml — build a new map with cartographer SLAM.

  Thin wrapper over middle_level in mapping mode (no localization, no global
  planner). Drive the car / sim around the track, then trigger finish_map
  (RViz "2D Goal Pose") to save <map>.{pbstream,png,yaml} under
  stack_master/maps/<map>/.

    ros2 launch stack_master mapping.launch.xml map:=YOURMAP            # real car
    ros2 launch stack_master mapping.launch.xml map:=YOURMAP sim:=true  # sim

  Generate the global raceline afterwards with raceline_generator.launch.xml.
-->
<launch>
  <arg name="map"                            description="Map name (folder created under stack_master/maps/)"/>
  <arg name="sim"           default="false"  description="Use simulator (true) or real hardware (false)"/>
  <let name="config_dir" value="$(find-pkg-share stack_master)/config/SIM" if="$(var sim)"/>
  <let name="config_dir" value="$(find-pkg-share stack_master)/config/CAR" unless="$(var sim)"/>
  <arg name="vehicle_config" default="$(var config_dir)/vehicle_config.yaml"/>
  <arg name="use_estop"     default="false"  description="Use emergency stop (true) or not (false)"/>

  <include file="$(find-pkg-share stack_master)/launch/middle_level.launch.xml">
    <arg name="sim"            value="$(var sim)"/>
    <arg name="map"            value="$(var map)"/>
    <arg name="mapping"        value="true"/>
    <arg name="vehicle_config" value="$(var vehicle_config)"/>
    <arg name="use_estop"      value="$(var use_estop)"/>
  </include>
</launch>
