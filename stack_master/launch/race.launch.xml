<?xml version="1.0"?>
<!--
  race.launch.xml  (ROS2 port of the ROS1 stack_master/headtohead.launch)
  ==============================================================================
  Full head-to-head racing autonomy on top of base_system:

    perception   : detect (C++) + tracking (Python)  (/scan -> /detect/raw_obstacles -> /tracking/obstacles_raw)
    state machine: state_machine                     (/tracking/obstacles + raceline -> /local_waypoints, /behavior_strategy, /state_machine)
    planning     : spliner_node                      (avoidance spline -> /planner/avoidance/otwpnts)
    control      : controller_manager               (L1/Pure-Pursuit; /behavior_strategy -> high_level/ackermann_cmd)

  The virtual opponent and its obstacle injection (/tracking/obstacles with
  Frenet fields) come from base_system -> low_level -> virtual_perception pkg
  (scan_overlay overlays the box on /scan; tracking_merger publishes
  /tracking/obstacles). Spawn / drive the opponent from the RViz Sim Control
  panel (2D Goal Pose, then Path/FTG).

  SIM : ros2 launch stack_master race.launch.xml map:=f sim:=true
  REAL: ros2 launch stack_master race.launch.xml map:=f sim:=false
-->
<launch>
  <arg name="map"        description="Map name (folder in stack_master/maps/)"/>
  <arg name="sim"        default="false" description="Use simulator (true) or real hardware (false)"/>
  <arg name="virtual"    default="$(var sim)" description="Inject a virtual opponent + static obstacles (on by default in sim, off on the real car; e.g. virtual:=true to overlay a virtual opponent onto the real LiDAR)"/>
  <arg name="ot_planner" default="predictive_spliner" description="overtake planner the state machine listens to (ROS1 default = predictive_spliner: listens to BOTH /planner/avoidance/otwpnts (dynamic) AND /planner/avoidance/static_otwpnts (static))"/>
  <arg name="control_topic" default="/local_waypoints"
       description="WpntArray the controller follows: /local_waypoints (state-machine output w/ avoidance) or /global_waypoints (robust raceline)"/>
  <arg name="use_pp_heading" default="false"
       description="Run pp_heading_controller instead of controller_manager (only one runs)"/>
  <arg name="reopt" default="false" description="Obstacle-aware global line (IFAC static re-optimization): static_reopt_node + static_obstacle_layer instead of plain global_trajectory_publisher"/>
  <arg name="reopt_safety_width" default="0.5" description="safety_width for the obstacle-aware re-optimizer (tight ifac map solves plain mincurv_iqp only at 0.25 or lower)"/>
  <!-- sim -> SIM config (racecar_f110.ini + veh_dyn_info); real hardware -> CAR. Folder name == racecar_version. -->
  <let name="racecar_version" value="SIM" if="$(var sim)"/>
  <let name="racecar_version" value="CAR" unless="$(var sim)"/>
  <!-- virtual_perception injection seam is chosen at RUNTIME from the Sim Control
       panel (/vp/inject_mode: overlay | merge; default 'overlay'). In BOTH modes
       tracking publishes /tracking/obstacles_raw and tracking_merger owns
       /tracking/obstacles (passes the real tracking through, and adds the virtual
       objects ONLY in 'merge' mode). So the REAL detect->track pipeline reaches the
       state machine in 'overlay' (detection-in-the-loop), and ground-truth object
       injection works in 'merge' — switchable live, no relaunch. -->

  <!-- ===== Base system: sensors/sim + opponent + raceline + frenet odom ===== -->
  <include file="$(find-pkg-share stack_master)/launch/base_system.launch.xml">
    <arg name="map"     value="$(var map)"/>
    <arg name="sim"     value="$(var sim)"/>
    <arg name="virtual" value="$(var virtual)"/>
    <arg name="reopt"   value="$(var reopt)"/>
    <arg name="reopt_safety_width" value="$(var reopt_safety_width)"/>
  </include>

  <!-- ===== Perception: LiDAR obstacle detection (C++) + tracking (Python) =====
       detect publishes /detect/raw_obstacles (Frenet filled at the source);
       tracking reads it and publishes /tracking/obstacles_raw. tracking_merger
       (sim virtual_perception) owns /tracking/obstacles. -->
  <node pkg="perception" exec="detect" name="detect" output="screen">
    <param from="$(find-pkg-share stack_master)/config/opponent_tracker_params.yaml"/>
    <param name="map" value="$(var map)"/>
  </node>
  <!-- with virtual:=true tracking_merger owns /tracking/obstacles, so tracking feeds it
       on /tracking/obstacles_raw; without it, tracking publishes /tracking/obstacles directly -->
  <let name="tracking_out" value="/tracking/obstacles_raw" if="$(var virtual)"/>
  <let name="tracking_out" value="/tracking/obstacles"     unless="$(var virtual)"/>
  <node pkg="perception" exec="tracking_node" name="tracking" output="screen">
    <param from="$(find-pkg-share stack_master)/config/opponent_tracker_params.yaml"/>
    <remap from="/tracking/obstacles" to="$(var tracking_out)"/>
  </node>

  <!-- ===== State machine: the racing brain ===== -->
  <node pkg="state_machine" exec="state_machine" name="state_machine" output="screen">
    <param from="$(find-pkg-share stack_master)/config/state_machine_params.yaml"/>
    <param name="sim"             value="$(var sim)"/>
    <param name="racecar_version" value="$(var racecar_version)"/>
    <param name="timetrials_only" value="false"/>
    <param name="ot_planner"      value="$(var ot_planner)"/>
    <param name="map"             value="$(var map)"/>
  </node>

  <!-- Recovery planner -> /planner/recovery/wpnts -->
  <node pkg="recovery_spliner" exec="recovery_spliner_node" name="recovery_spliner_node" output="screen"/>

  <!-- Start planner -> /planner/start_wpnts -->
  <node pkg="spliner" exec="start_spline_node_v2" name="start_planner" output="screen"/>

  <!-- Static avoidance (Frenet grid-sampling) -> /planner/avoidance/static_otwpnts
       + /planner/avoidance/static_feasible (Bool; SM gates OVERTAKE entry on it). The feasible
       topic is remapped like otwpnts so it doesn't collide with the dynamic spliner's namespace. -->
  <node pkg="spliner" exec="static_avoidance_node" name="static_avoidance_planner" output="screen">
    <param from="$(find-pkg-share stack_master)/config/static_avoidance_params.yaml"/>
    <remap from="/planner/avoidance/otwpnts" to="/planner/avoidance/static_otwpnts"/>
    <remap from="/planner/avoidance/feasible" to="/planner/avoidance/static_feasible"/>
  </node>

  <!-- Dynamic avoidance (ROS1 Change mode) -> /planner/avoidance/otwpnts + /planner/avoidance/merger -->
  <node pkg="lane_change_planner" exec="change_avoidance_node" name="planner_change" output="screen"/>
  <node pkg="lane_change_planner" exec="update_waypoints" name="waypoint_updater" output="screen"/>

  <!-- ===== GP opponent-trajectory predictor =====
       Pipeline (README): opponent_trajectory (collect /proj_opponent_trajectory) ->
       gaussian_process_opp_traj (GP fit -> /opponent_trajectory) -> opp_prediction
       (-> /opponent_prediction/* consumed by planner_change above).
       opp_prediction calls the frenet_conversion_server services, launched by base. -->
  <node pkg="gp_traj_predictor" exec="opponent_trajectory"       name="OpponentHalflap"                output="screen"/>
  <node pkg="gp_traj_predictor" exec="gaussian_process_opp_traj" name="GP_trajectory"                  output="screen" launch-prefix="taskset -c 1"/>
  <node pkg="gp_traj_predictor" exec="opp_prediction"           name="opponent_propagation_predictor" output="screen"/>

  <!-- ===== Control: L1 / Pure-Pursuit controller (ROS2 port of the ROS1 controller_manager) =====
       Subscribes /behavior_strategy + car state, publishes high_level/ackermann_cmd
       (-> simple_mux -> vehicle). Common controller.yaml; save_params writes back
       to the same file. -->
  <node pkg="controller" exec="controller_manager" name="controller_manager" output="screen"
        unless="$(var use_pp_heading)">
    <param from="$(find-pkg-share stack_master)/config/controller.yaml"/>
    <param name="save_yaml_path" value="$(find-pkg-share stack_master)/config/controller.yaml"/>
    <param name="sim" value="$(var sim)"/>
  </node>

  <node pkg="controller" exec="pp_heading_controller" name="pp_heading_controller" output="screen"
        if="$(var use_pp_heading)">
    <param from="$(find-pkg-share controller)/config/pp_heading_params.yaml"/>
    <remap from="/local_waypoints" to="$(var control_topic)"/>
  </node>
</launch>
