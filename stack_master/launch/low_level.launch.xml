<?xml version="1.0"?>
<launch>
  <!-- Arguments -->
  <arg name="sim"            default="false"      description="Use simulator (true) or real hardware (false)"/>
  <arg name="map"            default=""           description="Map name (required for sim, and for virtual:=true)"/>
  <let name="config_dir" value="$(find-pkg-share stack_master)/config/SIM" if="$(var sim)"/>
  <let name="config_dir" value="$(find-pkg-share stack_master)/config/CAR" unless="$(var sim)"/>
  <arg name="vehicle_config" default="$(var config_dir)/vehicle_config.yaml"/>
  <arg name="use_estop"      default="false"               description="Use emergency stop (true) or not (false)"/>
  <!-- Keyboard teleop: start keyboard_joy (pynput -> /joy_keyboard) and route the
       mux to it. The pitwall panel's Joy/Keyboard buttons can still switch at runtime. -->
  <arg name="keyboard_teleop" default="true"              description="Drive the ego with the keyboard instead of a joystick"/>
  <!-- Real-car lidar selection. The car now runs a Livox MID-360 as the primary sensor
       (kiss 3D localization + BEV detection). The Hokuyo is OFF by default because it is
       currently unplugged (urg_node otherwise retry-spams). NOTE: without the Hokuyo there
       is no /scan, so the FTG fallback (FTGONLY state / only_FTG zones / controller FTG)
       and use_estop are inert; re-enable with use_hokuyo:=true once it is reconnected. -->
  <arg name="use_hokuyo" default="false" description="Start the Hokuyo urg_node (/scan)"/>
  <arg name="use_livox"  default="true"  description="Start the Livox MID-360 driver (/livox/lidar + /livox/imu)"/>
  <!-- NOTE: livox_config is declared INSIDE the real-car use_livox group below, not here.
       ROS 2 launch evaluates arg defaults EAGERLY at parse time (even for an unused arg),
       and $(find-pkg-share livox_ros_driver2) throws when that hardware-only package is
       absent (it lives on the NUC, not in this repo, and is not built on a laptop). That
       broke sim:=true even though the livox node itself is already gated `unless sim`. -->

  <!-- virtual_perception (scan_overlay + virtual opponent + static obstacles).
       Defaults ON in sim (preserves prior behavior), OFF on the real car; toggle
       with virtual:=true (e.g. to overlay a virtual opponent onto the real LiDAR). -->
  <arg name="virtual"        default="$(var sim)"          description="Inject virtual opponent/obstacles into the perception stack"/>

  <!-- map paths (needed by the simulator and by virtual_perception in both sim and real) -->
  <let name="maps_dir" value="$(find-pkg-share stack_master)/maps"/>
  <let name="map_path" value="$(var maps_dir)/$(var map)/$(var map)"/>

  <!-- ========== REAL HARDWARE SENSORS ========== -->
  <group unless="$(var sim)">
    <!-- VESC: motor driver + ackermann converter + wheel odometry (/vesc/odom) -->
    <group>
      <push_ros_namespace namespace="vesc"/>
      <node pkg="vesc_driver" exec="vesc_driver_node" name="vesc_driver_node" output="screen">
        <param from="$(var vehicle_config)"/>
      </node>
      <include file="$(find-pkg-share vesc_ackermann)/launch/ackermann_to_vesc_node.launch.xml">
        <arg name="vesc_config" value="$(var vehicle_config)"/>
      </include>
      <include file="$(find-pkg-share vesc_ackermann)/launch/vesc_to_odom_node.launch.xml">
        <arg name="vesc_config" value="$(var vehicle_config)"/>
      </include>
    </group>

    <!-- Hokuyo 2D LiDAR: publishes /scan (frame_id: laser). With virtual:=true the raw scan
         goes to /scan_raw so scan_overlay (virtual_perception) can own /scan; otherwise the
         identity remap leaves it on /scan. Gated by use_hokuyo (see arg comment above). -->
    <let name="lidar_scan_out" value="/scan_raw" if="$(var virtual)"/>
    <let name="lidar_scan_out" value="/scan"     unless="$(var virtual)"/>
    <group if="$(var use_hokuyo)">
      <node pkg="urg_node" exec="urg_node_driver" name="urg_node" output="screen">
        <param from="$(var vehicle_config)"/>
        <remap from="/scan" to="$(var lidar_scan_out)"/>
      </node>
    </group>

    <!-- Livox MID-360 driver: /livox/lidar (PointCloud2, xfer_format=0; the kiss 3D
         localization + BEV detection input) + /livox/imu (~200 Hz). Sensor IPs live in
         the json (livox_config arg). -->
    <group if="$(var use_livox)">
      <!-- Resolved here (real car + use_livox only) so find-pkg-share is never evaluated in
           sim / on a laptop where livox_ros_driver2 is not built. See the note up top. -->
      <arg name="livox_config" default="$(find-pkg-share livox_ros_driver2)/config/MID360_config.json"
           description="Livox user config json (host/lidar IPs)"/>
      <node pkg="livox_ros_driver2" exec="livox_ros_driver2_node" name="livox_lidar_publisher" output="screen">
        <param name="xfer_format"      value="0"/>
        <param name="multi_topic"      value="0"/>
        <param name="data_src"         value="0"/>
        <param name="publish_freq"     value="10.0"/>
        <param name="output_data_type" value="0"/>
        <param name="frame_id"         value="livox_frame"/>
        <param name="user_config_path" value="$(var livox_config)"/>
      </node>
      <!-- Viz-only TF so the raw /livox/lidar cloud renders in RViz (kiss itself works in
           the sensor frame via extrinsic params, identity by config). Adjust xyz here if
           the mount offset should show in RViz. -->
      <node pkg="tf2_ros" exec="static_transform_publisher" name="base_to_livox_broadcaster"
            args="--x 0 --y 0 --z 0.1 --qx 0 --qy 0 --qz 0 --qw 1 --frame-id base_link --child-frame-id livox_frame"/>
    </group>

    <!-- Static TF: base_link → laser -->
    <node pkg="tf2_ros" exec="static_transform_publisher" name="base_to_laser_broadcaster"
          args="--x 0.27 --y 0 --z 0.11 --qx 0 --qy 0 --qz 0 --qw 1 --frame-id base_link --child-frame-id laser"/>
    <!-- Static TF: base_link -> vesc_imu (yaw +90 deg, Z axis same as base_link) -->
    <node pkg="tf2_ros" exec="static_transform_publisher" name="base_to_vesc_imu_broadcaster"
          args="--x 0 --y 0 --z 0.0 --roll 0 --pitch 0 --yaw 1.5707963 --frame-id base_link --child-frame-id vesc_imu"/>
    <!-- Static TF: vesc_imu -> vesc_imu_rot (reverse yaw=-90 deg: same orientation as base_link) -->
    <node pkg="tf2_ros" exec="static_transform_publisher" name="vesc_imu_to_rot_broadcaster"
          args="--x 0 --y 0 --z 0 --roll 0 --pitch 0 --yaw -1.5707963 --frame-id vesc_imu --child-frame-id vesc_imu_rot"/>

  </group>

  <!-- ========== SIMULATOR ========== -->
  <!-- gym_bridge: virtual /scan + odometry, optional TF -->
  <group if="$(var sim)">
    <!-- ego scan -> /scan_raw when the virtual overlay owns /scan, else straight to /scan -->
    <let name="gym_scan_out" value="/scan_raw" if="$(var virtual)"/>
    <let name="gym_scan_out" value="/scan"     unless="$(var virtual)"/>
    <include file="$(find-pkg-share f1tenth_gym_ros)/launch/gym_bridge_launch.py">
      <arg name="map_yaml_path" value="$(var map_path).yaml"/>
      <arg name="ego_scan_out"  value="$(var gym_scan_out)"/>
    </include>
  </group>

  <!-- ========== VIRTUAL PERCEPTION (sim + real) ==========
       The SAME package for both: base scan comes in on /scan_raw (gym or urg),
       scan_overlay owns /scan, and the virtual opponent + static obstacles +
       tracking_merger run. Gated by `virtual`; when off, the sensor owns /scan
       directly and none of these nodes start. -->
  <group if="$(var virtual)">
    <!-- The kinematic opponent_vehicle IS the opponent in BOTH sim and real:
         gym_bridge_launch.py hardcodes use_external_opponent=true, so the gym runs
         EGO-ONLY (no /goal_pose sub, no opp pubs/TF) and the virtual opponent owns the
         whole /goal_pose -> /opp_* -> overlay chain. Do NOT disable it in sim, or a
         2D Goal Pose spawns nothing. -->
    <include file="$(find-pkg-share virtual_perception)/launch/virtual_perception.launch.xml">
      <arg name="map_path"       value="$(var map_path).yaml"/>
      <arg name="ego_odom_topic" value="/car_state/odom"/>
      <arg name="scan_in"        value="/scan_raw"/>
      <arg name="scan_out"       value="/scan"/>
      <arg name="virtual_opponent" value="true"/>
    </include>
  </group>

  <!-- ========== ALWAYS ========== -->
  <!-- Keyboard teleop source (pynput -> /joy_keyboard). pynput needs a focused
       keyboard + display, so only start it here in sim (single machine). On the
       real (headless) car, run keyboard_joy_node on the operator laptop instead;
       keyboard_teleop:=true still flips the mux below to honour /joy_keyboard. -->
  <group if="$(var keyboard_teleop)">
    <node pkg="stack_master" exec="keyboard_joy_node.py" name="keyboard_joy" output="screen"
          if="$(var sim)"/>
  </group>

  <!-- Joystick / Command mux -->
  <node pkg="stack_master" exec="simple_mux_node.py" name="simple_mux" output="log">
    <param from="$(var vehicle_config)"/>
    <param name="in_topic"      value="/vesc/high_level/ackermann_cmd"/>
    <param name="out_topic"     value="/vesc/ackermann_cmd"/>
    <param name="joy_max_speed" value="4.0"/>
    <param name="use_estop" value="$(var use_estop)"/>
    <param name="sim" value="$(var sim)"/>
    <!-- start honouring /joy_keyboard immediately when keyboard teleop is on -->
    <param name="use_keyboard" value="$(var keyboard_teleop)"/>
  </node>

</launch>
