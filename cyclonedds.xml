    <Domain id="any">
        <General>
            <!-- <Interfaces>
                <NetworkInterface name="wlp~~~" multicast="false"/>
            </Interfaces> -->
            <Interfaces>
                <NetworkInterface address="192.168.60.0" multicast="false"/>
            </Interfaces>
